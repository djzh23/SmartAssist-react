# ── SmartAssist React Frontend — Environment Variables ─────
#
# Copy this file to .env.local for local development.
# Never commit .env.local to version control.

# Backend API base URL.
# - Leave empty in development: Vite will proxy /api/* to VITE_PROXY_TARGET below.
# - Set to your deployed backend origin for non-Vercel production deployments.
#   Example: https://your-backend.onrender.com
VITE_API_BASE_URL=

# Proxy target for local development (used by vite.config.ts).
# Requests to /api/* in dev are forwarded here server-side, avoiding CORS issues.
# Not needed in production (Vercel rewrites handle routing instead).
VITE_PROXY_TARGET=https://smartassist-api.onrender.com
