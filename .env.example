# ── SmartAssist React Frontend — Environment Variables ─────
#
# Copy this file to .env.local for local development.
# Never commit .env.local to version control.

# Backend API base URL.
# - Leave empty in development: the browser calls /api/* on the Vite dev server; Vite proxies to VITE_PROXY_TARGET.
# - Set to your deployed backend origin for production builds / non-proxy setups.
#   Example: https://your-backend.onrender.com
VITE_API_BASE_URL=

# Where Vite forwards /api/* in development (must match `dotnet run` URL, see SmartAssistApi launchSettings.json).
VITE_PROXY_TARGET=http://localhost:5194

# To proxy /api to production while developing (only if that API already has your routes):
# VITE_PROXY_TARGET=https://smartassist-api.onrender.com
# VITE_USE_REMOTE_API=1

# Optional: Landing Hero — „Nur noch X kostenlose Plätze“ (Standard: 42)
# VITE_REMAINING_FREE_SLOTS=37
